---
// app/src/layouts/AppLayout.astro
// Global HTML shell used by all pages.

import "../components/styles/global.css";

export interface Props {
  title?: string;
}
const { title = "Docker-YT-Uploader" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>