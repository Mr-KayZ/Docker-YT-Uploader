---
// app/src/pages/index.astro
import { initWatcher } from '../lib/watcher.js';
import { startScheduler } from '../lib/scheduler.js';
import { YT_CATEGORIES } from '../lib/uploader.js';

initWatcher();
startScheduler();
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Docker-YT-Uploader</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: system-ui, sans-serif;
      background: #f5f5f5;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* --- Header --- */
    header {
      background: white;
      border-bottom: 1px solid #e5e5e5;
      padding: 0.875rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    header .logo-mark {
      flex-shrink: 0;
    }
    header h1 {
      font-size: 1rem;
      font-weight: 600;
      color: #1a1a1a;
    }
    header .subtitle {
      font-size: 0.8rem;
      color: #888;
      margin-left: auto;
    }

    /* --- Layout --- */
    .workspace {
      display: flex;
      flex: 1;
      overflow: hidden;
      height: calc(100vh - 53px);
    }

    /* --- Left panel --- */
    .panel-left {
      width: 320px;
      flex-shrink: 0;
      background: white;
      border-right: 1px solid #e5e5e5;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .panel-left-header {
      padding: 1rem 1.25rem 0.75rem;
      border-bottom: 1px solid #f0f0f0;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .panel-left-header h2 {
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #888;
    }
    .file-count {
      font-size: 0.75rem;
      background: #f0f0f0;
      color: #555;
      padding: 0.15rem 0.5rem;
      border-radius: 999px;
    }
    .file-list {
      flex: 1;
      overflow-y: auto;
      padding: 0.5rem;
    }
    .file-empty {
      padding: 2rem 1rem;
      text-align: center;
      color: #aaa;
      font-size: 0.85rem;
      line-height: 1.6;
    }
    .file-item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 0.75rem;
      border-radius: 8px;
      cursor: pointer;
      border: 1px solid transparent;
      transition: background 0.1s, border-color 0.1s;
      margin-bottom: 0.25rem;
    }
    .file-item:hover { background: #f9f9f9; }
    .file-item.selected {
      background: #f0f0f0;
      border-color: #d0d0d0;
    }
    .file-item.queued   { opacity: 0.5; pointer-events: none; }
    .file-item.uploading { border-color: #2563eb; background: #eff6ff; }
    .file-item.done     { opacity: 0.5; pointer-events: none; }
    .file-icon {
      width: 36px;
      height: 36px;
      background: #f5f5f5;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      color: #888;
    }
    .file-info { min-width: 0; flex: 1; }
    .file-name {
      font-size: 0.85rem;
      font-weight: 500;
      color: #1a1a1a;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .file-meta {
      font-size: 0.75rem;
      color: #999;
      margin-top: 0.2rem;
    }
    .badge {
      font-size: 0.7rem;
      font-weight: 600;
      padding: 0.1rem 0.45rem;
      border-radius: 4px;
      flex-shrink: 0;
      align-self: center;
    }
    .badge-queued    { background: #fef3c7; color: #92400e; }
    .badge-uploading { background: #dbeafe; color: #1d4ed8; }
    .badge-done      { background: #dcfce7; color: #166534; }
    .badge-failed    { background: #fee2e2; color: #991b1b; }

    /* --- Right panel --- */
    .panel-right {
      flex: 1;
      overflow-y: auto;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .form-inner {
      width: 100%;
      max-width: 600px;
    }

    /* Idle state */
    .idle-state {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: #bbb;
      text-align: center;
      gap: 0.75rem;
    }
    .idle-state p { font-size: 0.9rem; }

    /* --- Reuse setup.astro card/step styles --- */
    .card-header {
      margin-bottom: 1.25rem;
    }
    .card-header h2 {
      font-size: 1.1rem;
      font-weight: 600;
      color: #1a1a1a;
      margin-bottom: 0.2rem;
    }
    .card-header p {
      font-size: 0.85rem;
      color: #666;
    }
    .step {
      border: 1px solid #e5e5e5;
      border-radius: 8px;
      padding: 1.25rem;
      margin-bottom: 1rem;
    }
    .step-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }
    .step-num {
      background: #1a1a1a;
      color: white;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      font-weight: 600;
      flex-shrink: 0;
    }
    .step h3 {
      font-size: 0.95rem;
      font-weight: 600;
    }

    /* --- Form controls --- */
    .field { margin-bottom: 0.875rem; }
    .field:last-child { margin-bottom: 0; }
    label {
      display: block;
      font-size: 0.8rem;
      font-weight: 500;
      color: #444;
      margin-bottom: 0.3rem;
    }
    .field-hint {
      font-size: 0.75rem;
      color: #999;
      margin-top: 0.25rem;
    }
    input[type="text"],
    input[type="datetime-local"],
    select,
    textarea {
      width: 100%;
      padding: 0.5rem 0.75rem;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      font-size: 0.875rem;
      color: #1a1a1a;
      background: white;
      transition: border-color 0.15s, box-shadow 0.15s;
      outline: none;
    }
    input:focus, select:focus, textarea:focus {
      border-color: #1a1a1a;
      box-shadow: 0 0 0 3px rgba(0,0,0,0.06);
    }
    textarea { resize: vertical; min-height: 100px; line-height: 1.5; }
    .char-counter {
      font-size: 0.75rem;
      color: #999;
      text-align: right;
      margin-top: 0.25rem;
    }
    .char-counter.warn { color: #dc2626; }

    .radio-group { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .radio-btn { position: relative; }
    .radio-btn input { position: absolute; opacity: 0; width: 0; height: 0; }
    .radio-btn label {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.4rem 0.85rem;
      border: 1px solid #d1d5db;
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.82rem;
      font-weight: 400;
      color: #444;
      transition: border-color 0.15s, background 0.15s;
      margin: 0;
    }
    .radio-btn input:checked + label {
      border-color: #1a1a1a;
      background: #1a1a1a;
      color: white;
    }

    /* Drop zones */
    .drop-zone {
      border: 2px dashed #d1d5db;
      border-radius: 8px;
      padding: 1rem;
      text-align: center;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
    }
    .drop-zone:hover, .drop-zone.dragover {
      border-color: #1a1a1a;
      background: #f9f9f9;
    }
    .drop-zone.has-file {
      border-color: #16a34a;
      background: #f0fdf4;
    }
    .drop-zone p { font-size: 0.82rem; color: #666; pointer-events: none; }
    .drop-zone .drop-hint { font-size: 0.75rem; color: #aaa; margin-top: 0.25rem; pointer-events: none; }
    input[type="file"] { display: none; }

    /* Schedule toggle */
    .toggle-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.75rem;
    }
    .toggle-row label { margin: 0; font-size: 0.875rem; font-weight: 500; color: #1a1a1a; }
    .toggle {
      position: relative;
      width: 36px;
      height: 20px;
    }
    .toggle input { opacity: 0; width: 0; height: 0; }
    .toggle-slider {
      position: absolute;
      inset: 0;
      background: #d1d5db;
      border-radius: 999px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .toggle-slider::before {
      content: '';
      position: absolute;
      width: 14px; height: 14px;
      left: 3px; top: 3px;
      background: white;
      border-radius: 50%;
      transition: transform 0.2s;
    }
    .toggle input:checked + .toggle-slider { background: #1a1a1a; }
    .toggle input:checked + .toggle-slider::before { transform: translateX(16px); }
    .collapsible { overflow: hidden; transition: max-height 0.25s ease; }
    .collapsible.collapsed { max-height: 0 !important; }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      width: 100%;
      padding: 0.75rem;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      border: none;
      text-decoration: none;
      transition: background 0.15s;
    }
    .btn-primary { background: #1a1a1a; color: white; }
    .btn-primary:hover { background: #333; }
    .btn-primary:disabled { background: #9ca3af; cursor: not-allowed; }
    .btn-secondary {
      background: white;
      color: #1a1a1a;
      border: 1px solid #d1d5db;
      margin-top: 0.5rem;
    }
    .btn-secondary:hover { background: #f5f5f5; }

    .submit-area { margin-top: 0.25rem; }

    /* Status banner */
    .status-bar {
      padding: 0.6rem 0.9rem;
      border-radius: 8px;
      font-size: 0.85rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }
    .status-bar.info    { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
    .status-bar.success { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }
    .status-bar.error   { background: #fef2f2; color: #991b1b; border: 1px solid #fca5a5; }
    .status-bar.hidden  { display: none; }
  </style>
</head>
<body>

  <!-- Header -->
  <header>
    <svg class="logo-mark" width="28" height="28" viewBox="0 0 32 32" fill="none" aria-label="Docker-YT-Uploader">
      <rect width="32" height="32" rx="8" fill="#1a1a1a"/>
      <polygon points="12,10 24,16 12,22" fill="white"/>
    </svg>
    <h1>Docker-YT-Uploader</h1>
    <span class="subtitle">Watching <code>/uploads</code></span>
  </header>

  <div class="workspace">

    <!-- --- Left panel: file list --- -->
    <aside class="panel-left">
      <div class="panel-left-header">
        <h2>Upload Queue</h2>
        <span class="file-count" id="fileCount">0</span>
      </div>
      <div class="file-list" id="fileList">
        <div class="file-empty">
          <p>No video files detected.<br/>Drop a file into <code>/uploads</code>.</p>
        </div>
      </div>
    </aside>

    <!-- --- Right panel: upload form --- -->
    <main class="panel-right" id="panelRight">

      <!-- Idle placeholder (shown when nothing is selected) -->
      <div class="idle-state" id="idleState">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="5 3 19 12 5 21 5 3"/>
        </svg>
        <p>Select a video on the left<br/>to configure its upload.</p>
      </div>

      <!-- Upload form (hidden until a file is selected) -->
      <div class="form-inner" id="uploadForm" style="display:none">

        <div class="card-header">
          <h2 id="formFileName">video.mp4</h2>
          <p>Configure and queue this video for YouTube.</p>
        </div>

        <div class="status-bar hidden" id="statusBar"></div>

        <!-- Step 1: Basic Info -->
        <div class="step">
          <div class="step-header">
            <div class="step-num">1</div>
            <h3>Basic Info</h3>
          </div>

          <div class="field">
            <label for="title">Title <span style="color:#dc2626">*</span></label>
            <input type="text" id="title" name="title" maxlength="100" placeholder="My awesome video" />
            <div class="char-counter"><span id="titleCount">0</span> / 100</div>
          </div>

          <div class="field">
            <label for="description">Description</label>
            <textarea id="description" name="description" maxlength="5000" placeholder="Describe your video..."></textarea>
            <div class="char-counter"><span id="descCount">0</span> / 5000</div>
          </div>

          <div class="field">
            <label for="tags">Tags</label>
            <input type="text" id="tags" name="tags" placeholder="gaming, tutorial, walkthrough" />
            <p class="field-hint">Comma-separated. Helps with search discovery.</p>
          </div>

          <div class="field">
            <label for="language">Video Language</label>
            <select id="language" name="language">
              <option value="en">English</option>
              <option value="fr">French</option>
              <option value="de">German</option>
              <option value="es">Spanish</option>
              <option value="ja">Japanese</option>
              <option value="ko">Korean</option>
              <option value="zh-Hans">Chinese (Simplified)</option>
              <option value="pt">Portuguese</option>
            </select>
          </div>
        </div>

        <!-- Step 2: Details -->
        <div class="step">
          <div class="step-header">
            <div class="step-num">2</div>
            <h3>Details</h3>
          </div>

          <div class="field">
            <label for="categoryId">Category</label>
            <select id="categoryId" name="categoryId">
              {Object.entries(YT_CATEGORIES).map(([id, name]) => (
                <option value={id}>{name}</option>
              ))}
            </select>
          </div>

          <div class="field">
            <label>Audience</label>
            <div class="radio-group">
              <div class="radio-btn">
                <input type="radio" name="audience" id="aud-general" value="general" checked />
                <label for="aud-general">General</label>
              </div>
              <div class="radio-btn">
                <input type="radio" name="audience" id="aud-kids" value="kids" />
                <label for="aud-kids">Made for Kids</label>
              </div>
              <div class="radio-btn">
                <input type="radio" name="audience" id="aud-18" value="age_restricted" />
                <label for="aud-18">Age-restricted (18+)</label>
              </div>
            </div>
            <p class="field-hint">Required by YouTube. "Made for Kids" disables comments and personalised ads.</p>
          </div>
        </div>

        <!-- Step 3: Thumbnail -->
        <div class="step">
          <div class="step-header">
            <div class="step-num">3</div>
            <h3>Thumbnail</h3>
          </div>
          <div class="drop-zone" id="thumbZone">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 0.4rem">
              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
            <p><strong>Drop thumbnail here</strong> or click to browse</p>
            <p class="drop-hint">JPG or PNG · Recommended 1280×720 · Max 2 MB</p>
          </div>
          <input type="file" id="thumbInput" accept=".jpg,.jpeg,.png" />
        </div>

        <!-- Step 4: Captions -->
        <div class="step">
          <div class="step-header">
            <div class="step-num">4</div>
            <h3>Captions / Subtitles <span style="font-weight:400;color:#888;font-size:0.8rem">(optional)</span></h3>
          </div>
          <div class="drop-zone" id="capZone">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin:0 auto 0.4rem">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/>
            </svg>
            <p><strong>Drop .srt or .vtt file here</strong> or click to browse</p>
            <p class="drop-hint">Will be uploaded to YouTube after the video processes.</p>
          </div>
          <input type="file" id="capInput" accept=".srt,.vtt" />
          <div class="field" style="margin-top:0.75rem">
            <label for="captionLanguage">Caption Language</label>
            <select id="captionLanguage" name="captionLanguage">
              <option value="en">English</option>
              <option value="fr">French</option>
              <option value="de">German</option>
              <option value="es">Spanish</option>
              <option value="ja">Japanese</option>
              <option value="ko">Korean</option>
            </select>
          </div>
          <p class="field-hint" style="margin-top:0.4rem">
            Note: End screens and info cards cannot be set via the YouTube API - configure those in YouTube Studio after upload.
          </p>
        </div>

        <!-- Step 5: Publishing -->
        <div class="step">
          <div class="step-header">
            <div class="step-num">5</div>
            <h3>Publishing Options</h3>
          </div>

          <div class="field">
            <label>Visibility</label>
            <div class="radio-group">
              <div class="radio-btn">
                <input type="radio" name="privacyStatus" id="priv-private" value="private" checked />
                <label for="priv-private">Private</label>
              </div>
              <div class="radio-btn">
                <input type="radio" name="privacyStatus" id="priv-unlisted" value="unlisted" />
                <label for="priv-unlisted">Unlisted</label>
              </div>
              <div class="radio-btn">
                <input type="radio" name="privacyStatus" id="priv-public" value="public" />
                <label for="priv-public">Public</label>
              </div>
            </div>
          </div>

          <div class="field">
            <div class="toggle-row">
              <label for="schedPubToggle">Schedule publish date</label>
              <label class="toggle">
                <input type="checkbox" id="schedPubToggle" />
                <span class="toggle-slider"></span>
              </label>
            </div>
            <div class="collapsible collapsed" id="schedPubField" style="max-height:60px">
              <input type="datetime-local" id="publishAt" name="publishAt" />
              <p class="field-hint">The video uploads as Private, then goes live at this date &amp; time.</p>
            </div>
          </div>
        </div>

        <!-- Step 6: Upload Scheduling -->
        <div class="step">
          <div class="step-header">
            <div class="step-num">6</div>
            <h3>Upload Schedule</h3>
          </div>
          <div class="field">
            <div class="toggle-row">
              <label for="schedUploadToggle">Schedule upload time</label>
              <label class="toggle">
                <input type="checkbox" id="schedUploadToggle" />
                <span class="toggle-slider"></span>
              </label>
            </div>
            <div class="collapsible collapsed" id="schedUploadField" style="max-height:60px">
              <input type="datetime-local" id="scheduledUploadAt" name="scheduledUploadAt" />
              <p class="field-hint">The upload to YouTube will start at this time. Leave off to upload immediately.</p>
            </div>
          </div>
        </div>

        <!-- Submit -->
        <div class="submit-area">
          <button class="btn btn-primary" id="submitBtn" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/>
              <path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/>
            </svg>
            Upload to YouTube
          </button>
          <button class="btn btn-secondary" id="clearBtn" type="button">Clear form</button>
        </div>

      </div>
    </main>
  </div>

<script>
  // State
  //-----------------------------------------------------------------------------------------------
  let selectedFile: string | null = null;
  let thumbFile: File | null = null;
  let capFile:   File | null = null;

  // DOM refs
  //-----------------------------------------------------------------------------------------------
  const fileList      = document.getElementById('fileList')!;
  const fileCount     = document.getElementById('fileCount')!;
  const idleState     = document.getElementById('idleState')!;
  const uploadForm    = document.getElementById('uploadForm')!;
  const formFileName  = document.getElementById('formFileName')!;
  const statusBar     = document.getElementById('statusBar')!;
  const submitBtn     = document.getElementById('submitBtn') as HTMLButtonElement;
  const clearBtn      = document.getElementById('clearBtn')!;
  const titleInput    = document.getElementById('title') as HTMLInputElement;
  const titleCount    = document.getElementById('titleCount')!;
  const descInput     = document.getElementById('description') as HTMLTextAreaElement;
  const descCount     = document.getElementById('descCount')!;
  const thumbZone     = document.getElementById('thumbZone')!;
  const thumbInput    = document.getElementById('thumbInput') as HTMLInputElement;
  const capZone       = document.getElementById('capZone')!;
  const capInput      = document.getElementById('capInput') as HTMLInputElement;
  const schedPubToggle   = document.getElementById('schedPubToggle')   as HTMLInputElement;
  const schedPubField    = document.getElementById('schedPubField')!;
  const schedUploadToggle = document.getElementById('schedUploadToggle') as HTMLInputElement;
  const schedUploadField  = document.getElementById('schedUploadField')!;
  const publishAtInput    = document.getElementById('publishAt') as HTMLInputElement;
  const scheduledUploadAtInput = document.getElementById('scheduledUploadAt') as HTMLInputElement;

  // Character counters
  //-----------------------------------------------------------------------------------------------
  titleInput.addEventListener('input', () => {
    const n = titleInput.value.length;
    titleCount.textContent = String(n);
    titleCount.parentElement!.classList.toggle('warn', n > 90);
  });
  descInput.addEventListener('input', () => {
    const n = descInput.value.length;
    descCount.textContent = String(n);
    descCount.parentElement!.classList.toggle('warn', n > 4800);
  });

  // Toggle collapse
  //-----------------------------------------------------------------------------------------------
  schedPubToggle.addEventListener('change', () => {
    schedPubField.classList.toggle('collapsed', !schedPubToggle.checked);
    if (!schedPubToggle.checked) publishAtInput.value = '';
    // If scheduling publish, force visibility to private
    if (schedPubToggle.checked) {
      (document.getElementById('priv-private') as HTMLInputElement).checked = true;
    }
  });
  schedUploadToggle.addEventListener('change', () => {
    schedUploadField.classList.toggle('collapsed', !schedUploadToggle.checked);
    if (!schedUploadToggle.checked) scheduledUploadAtInput.value = '';
  });

  // Drop zones (thumbnail)
  //-----------------------------------------------------------------------------------------------
  setupDropZone(thumbZone, thumbInput, ['image/jpeg', 'image/png'], (file) => {
    thumbFile = file;
    thumbZone.classList.add('has-file');
    thumbZone.innerHTML = `<p style="color:#166534">✓ <strong>${file.name}</strong></p>`;
  });

  // Drop zones (captions)
  //-----------------------------------------------------------------------------------------------
  setupDropZone(capZone, capInput, [], (file) => {
    capFile = file;
    capZone.classList.add('has-file');
    capZone.innerHTML = `<p style="color:#166534">✓ <strong>${file.name}</strong></p>`;
  });

  function setupDropZone(zone: HTMLElement, input: HTMLInputElement, allowedTypes: string[], onFile: (f: File) => void) {
    zone.addEventListener('click', () => input.click());
    zone.addEventListener('dragover', (e) => { e.preventDefault(); zone.classList.add('dragover'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
    zone.addEventListener('drop', (e) => {
      e.preventDefault();
      zone.classList.remove('dragover');
      const f = (e as DragEvent).dataTransfer?.files[0];
      if (f && (allowedTypes.length === 0 || allowedTypes.includes(f.type))) onFile(f);
    });
    input.addEventListener('change', () => {
      const f = input.files?.[0];
      if (f) onFile(f);
    });
  }

  // File list polling
  //-----------------------------------------------------------------------------------------------
  async function refreshFileList() {
    try {
      const [filesRes, uploadRes] = await Promise.all([
        fetch('/api/files'),
        fetch('/api/enqueue'),
      ]);
      const { files } = await filesRes.json() as { ready: boolean; files: { name: string; path: string; addedAt: string }[] };
      const { queue, history } = await uploadRes.json() as {
        queue:   { fileName: string; status: string }[];
        history: { fileName: string; status: string }[];
      };

      const queueMap = new Map([
        ...queue.map(e => [e.fileName, e.status] as [string, string]),
        ...history.map(e => [e.fileName, e.status] as [string, string]),
      ]);

      fileCount.textContent = String(files.length);

      if (files.length === 0) {
        fileList.innerHTML = `<div class="file-empty"><p>No video files detected.<br/>Drop a file into <code>/uploads</code>.</p></div>`;
        return;
      }

      fileList.innerHTML = files.map(f => {
        const status = queueMap.get(f.name) ?? '';
        const statusClass = status ? ` ${status}` : '';
        const badge = status
          ? `<span class="badge badge-${status}">${status}</span>`
          : '';
        const added = new Date(f.addedAt).toLocaleString();
        return `
          <div class="file-item${statusClass}${selectedFile === f.name ? ' selected' : ''}"
               data-name="${f.name}" data-path="${f.path}">
            <div class="file-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
              </svg>
            </div>
            <div class="file-info">
              <div class="file-name">${f.name}</div>
              <div class="file-meta">${added}</div>
            </div>
            ${badge}
          </div>`;
      }).join('');

      // Re-attach click handlers
      fileList.querySelectorAll('.file-item').forEach(el => {
        el.addEventListener('click', () => selectFile(el.getAttribute('data-name')!));
      });

    } catch (err) {
      console.error('[ui] refreshFileList error:', err);
    }
  }

  function selectFile(name: string) {
    selectedFile = name;
    formFileName.textContent = name;
    idleState.style.display  = 'none';
    uploadForm.style.display = 'block';
    // Pre-fill title from filename (strip extension)
    if (!titleInput.value) {
      titleInput.value = name.replace(/\.[^/.]+$/, '');
      titleCount.textContent = String(titleInput.value.length);
    }
    hideStatus();
    refreshFileList();
  }

  // Submit
  //-----------------------------------------------------------------------------------------------
  submitBtn.addEventListener('click', async () => {
    if (!selectedFile) return;
    submitBtn.disabled = true;
    submitBtn.textContent = 'Queuing…';
    hideStatus();

    const form = new FormData();
    form.append('fileName',        selectedFile);
    form.append('title',           titleInput.value.trim());
    form.append('description',     (document.getElementById('description') as HTMLTextAreaElement).value);
    form.append('tags',            (document.getElementById('tags')        as HTMLInputElement).value);
    form.append('categoryId',      (document.getElementById('categoryId') as HTMLSelectElement).value);
    form.append('language',        (document.getElementById('language')   as HTMLSelectElement).value);
    form.append('captionLanguage', (document.getElementById('captionLanguage') as HTMLSelectElement).value);
    form.append('audience',        (document.querySelector('input[name="audience"]:checked') as HTMLInputElement)?.value ?? 'general');
    form.append('privacyStatus',   (document.querySelector('input[name="privacyStatus"]:checked') as HTMLInputElement)?.value ?? 'private');
    if (schedPubToggle.checked && publishAtInput.value)
      form.append('publishAt', new Date(publishAtInput.value).toISOString());
    if (schedUploadToggle.checked && scheduledUploadAtInput.value)
      form.append('scheduledUploadAt', new Date(scheduledUploadAtInput.value).toISOString());
    if (thumbFile) form.append('thumbnail', thumbFile);
    if (capFile)   form.append('caption',   capFile);

    try {
      const res  = await fetch('/api/enqueue', { method: 'POST', body: form });
      const data = await res.json();
      if (res.ok) {
        showStatus(
          schedUploadToggle.checked
            ? `Scheduled for upload at ${scheduledUploadAtInput.value}.`
            : 'Upload started - check back shortly.',
          'success'
        );
        selectedFile = null;
        setTimeout(() => {
          idleState.style.display  = 'flex';
          uploadForm.style.display = 'none';
        }, 3000);
      } else {
        showStatus(data.error ?? 'Something went wrong.', 'error');
      }
    } catch {
      showStatus('Network error - check server logs.', 'error');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg> Upload to YouTube`;
      refreshFileList();
    }
  });

  clearBtn.addEventListener('click', () => {
    titleInput.value = '';
    descInput.value  = '';
    (document.getElementById('tags') as HTMLInputElement).value = '';
    thumbFile = capFile = null;
    titleCount.textContent = '0';
    descCount.textContent  = '0';
    schedPubToggle.checked = schedUploadToggle.checked = false;
    schedPubField.classList.add('collapsed');
    schedUploadField.classList.add('collapsed');
    publishAtInput.value = scheduledUploadAtInput.value = '';
    hideStatus();
  });

  // Status bar helpers
  //-----------------------------------------------------------------------------------------------
  function showStatus(msg: string, type: 'info' | 'success' | 'error') {
    statusBar.textContent = msg;
    statusBar.className   = `status-bar ${type}`;
  }
  function hideStatus() {
    statusBar.className = 'status-bar hidden';
  }

  // Boot
  //-----------------------------------------------------------------------------------------------
  refreshFileList();
  setInterval(refreshFileList, 5000);
</script>

</body>
</html>