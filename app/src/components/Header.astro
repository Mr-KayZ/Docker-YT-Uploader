---
// app/src/components/Header.astro
// App header: logo, title, and watch-folder subtitle.
---

<header>
  <svg class="logo-mark" width="28" height="28" viewBox="0 0 32 32" fill="none" aria-label="Docker-YT-Uploader">
    <rect width="32" height="32" rx="8" fill="#1a1a1a"/>
    <polygon points="12,10 24,16 12,22" fill="white"/>
  </svg>
  <h1>Docker-YT-Uploader</h1>
  <span class="subtitle">Watching <code>/videos</code></span>
</header>

<style>
  header {
    background: white;
    border-bottom: 1px solid #e5e5e5;
    padding: 0.875rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  header .logo-mark { flex-shrink: 0; }
  header h1 {
    font-size: 1rem;
    font-weight: 600;
    color: #1a1a1a;
  }
  header .subtitle {
    font-size: 0.8rem;
    color: #888;
    margin-left: auto;
  }
</style>