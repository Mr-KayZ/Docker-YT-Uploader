---
// app/src/components/IdleState.astro
// Shown in the right pane when no file is selected.
---

<div class="idle-state" id="idleState">
  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#d1d5db"
       stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <polygon points="5 3 19 12 5 21 5 3"/>
  </svg>
  <p>Select a video on the left<br/>to configure its upload.</p>
</div>

<style>
  .idle-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #bbb;
    text-align: center;
    gap: 0.75rem;
  }
  .idle-state p { font-size: 0.9rem; }
</style>