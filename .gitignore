# Dependencies
node_modules/

# Build output
dist/
.astro/

# Environment variables (never commit these)
.env
.env.*
!.env.example

# Videos folder contents (mount this as a volume, don't track files)
videos/*
!videos/.gitkeep

# Auth folder contents (mount this as a volume, don't track files)
auth/client_secret.json
auth/tokens.json

# Data folder
data/*
!data/.gitkeep

# Docker
*.log

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/
*.swp

# Testing directory - Not for production
Docker-YT-Test-media/*