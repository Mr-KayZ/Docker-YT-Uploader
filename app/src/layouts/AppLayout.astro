---
// app/src/layouts/AppLayout.astro
// Global HTML shell used by all pages. Import global.css here so styles
// are consistent across index.astro and setup.astro.

export interface Props {
  title?: string;
}
const { title = 'Docker-YT-Uploader' } = Astro.props;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="stylesheet" href="/src/components/styles/global.css" />
</head>
<body>
  <slot />
</body>
</html>