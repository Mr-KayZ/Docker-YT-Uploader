---
import { initWatcher, getWatchedFiles } from '../lib/watcher';

initWatcher();
const files = getWatchedFiles();
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Docker-YT-Uploader</title>
    <style>
      body { font-family: sans-serif; max-width: 800px; margin: 2rem auto; padding: 0 1rem; }
      h1 { font-size: 1.5rem; margin-bottom: 0.25rem; }
      .subtitle { color: #666; font-size: 0.9rem; margin-bottom: 1.5rem; }
      .empty { background: #f5f5f5; border: 1px solid #ddd; padding: 1.5rem;
               border-radius: 6px; color: #555; text-align: center; }
      table { width: 100%; border-collapse: collapse; }
      th { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 2px solid #ddd;
           font-size: 0.85rem; color: #444; }
      td { padding: 0.5rem 0.75rem; border-bottom: 1px solid #eee; font-size: 0.9rem; }
      .count { margin-top: 1rem; font-size: 0.85rem; color: #666; }
    </style>
  </head>
  <body>
    <h1>Docker-YT-Uploader</h1>
    <p class="subtitle">Watching <code>/uploads</code> for video files</p>

    {files.length === 0 ? (
      <div class="empty">
        <p>No video files detected yet.</p>
        <p>Drop a supported video file (<code>.mp4</code>, <code>.mkv</code>, <code>.mov</code>, etc.) into the <code>uploads/</code> folder.</p>
      </div>
    ) : (
      <>
        <table>
          <thead>
            <tr>
              <th>Filename</th>
              <th>Detected At</th>
            </tr>
          </thead>
          <tbody>
            {files.map((file) => (
              <tr>
                <td>{file.name}</td>
                <td>{file.addedAt.toLocaleString()}</td>
              </tr>
            ))}
          </tbody>
        </table>
        <p class="count">{files.length} file{files.length !== 1 ? 's' : ''} detected</p>
      </>
    )}
  </body>
</html>