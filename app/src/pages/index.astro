---
// app/src/pages/index.astro
// Thin orchestrator: initialises server-side services, composes components,
// and owns the file-list polling loop + file-selection event bridge.

import AppLayout from "../layouts/AppLayout.astro";
import Header from "../components/Header.astro";
import FilePanel from "../components/FilePanel.astro";
import UploadForm from "../components/UploadForm.astro";

import { initWatcher } from "../lib/watcher.ts";
import { startScheduler } from "../lib/scheduler.ts";

initWatcher();
startScheduler();
---

<AppLayout title="Docker-YT-Uploader">
  <Header />

  <div class="workspace">
    <FilePanel />

    <!-- Right pane: either UploadForm or DonePanel depending on selection -->
    <div class="panel-right-wrapper" id="panelRightWrapper">
      <UploadForm />

      <!-- DonePanel: shown when a completed video is selected -->
      <div class="done-panel" id="donePanel" style="display:none">
        <div class="done-panel-inner">
          <!-- YouTube link -->
          <a
            class="yt-link-btn"
            id="ytLinkBtn"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path
                d="M19.59 6.69a4.83 4.83 0 0 1-3.77-2.75 12.38 12.38 0 0 0-7.64 0A4.83 4.83 0 0 1 4.41 6.69 41.76 41.76 0 0 0 4 12a41.76 41.76 0 0 0 .41 5.31 4.83 4.83 0 0 1 3.77 2.75 12.38 12.38 0 0 0 7.64 0 4.83 4.83 0 0 1 3.77-2.75A41.76 41.76 0 0 0 20 12a41.76 41.76 0 0 0-.41-5.31zM10 15.5v-7l6 3.5z"
              ></path>
            </svg>
            View on YouTube
          </a>

          <div class="done-panel-header">
            <div class="done-loading" id="doneLoading">
              <div class="done-spinner"></div>
              <span>Loading from YouTube…</span>
            </div>
            <div class="done-error" id="doneError" style="display:none"></div>
            <div id="doneMeta" style="display:none">
              <div class="card-header">
                <h2 id="doneTitle"></h2>
                <div class="done-stats" id="doneStats"></div>
              </div>

              <div class="done-field">
                <label>Description</label>
                <div class="done-textarea" id="doneDescription"></div>
              </div>

              <div class="done-field">
                <label>Tags</label>
                <div class="done-tags" id="doneTags"></div>
              </div>

              <div class="done-field-row">
                <div class="done-field">
                  <label>Privacy</label>
                  <div class="done-value" id="donePrivacy"></div>
                </div>
                <div class="done-field">
                  <label>Published</label>
                  <div class="done-value" id="donePublished"></div>
                </div>
              </div>
            </div>
          </div>

          <button
            class="btn btn-secondary done-back-btn"
            id="doneBackBtn"
            type="button"
          >
            ← Back to uploader
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom-left upload progress card -->
  <div class="upload-card" id="uploadCard" aria-live="polite">
    <div class="upload-card-header">
      <div class="upload-spinner" aria-hidden="true"></div>
      <span class="upload-card-title" id="uploadCardTitle">Uploading…</span>
    </div>
    <div class="upload-card-filename" id="uploadCardFilename"></div>
    <div class="upload-progress-track">
      <div class="upload-progress-bar" id="uploadProgressBar"></div>
    </div>
    <div class="upload-card-meta">
      <span id="uploadCardPercent">0%</span>
      <span id="uploadCardSpeed"></span>
    </div>
    <div class="upload-card-quota" id="uploadCardQuota"></div>
  </div>
</AppLayout>

<style>
  /* Right pane wrapper - fills the remaining space, clips its children */
  .panel-right-wrapper {
    flex: 1;
    min-width: 0;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  /* UploadForm's panel-right needs to fill and scroll within the wrapper */
  :global(.panel-right) {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
  }

  /* Done panel */
  .done-panel {
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .done-panel-inner {
    width: 100%;
    max-width: 600px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* YouTube link button */
  .yt-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #dc2626;
    color: white;
    padding: 0.6rem 1.1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    align-self: flex-start;
    transition: background 0.15s;
  }
  .yt-link-btn:hover {
    background: #b91c1c;
  }

  /* Loading / error states */
  .done-loading {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: #888;
    font-size: 0.875rem;
    padding: 2rem 0;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  .done-spinner {
    width: 16px;
    height: 16px;
    border: 2px solid #e5e5e5;
    border-top-color: #2563eb;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    flex-shrink: 0;
  }
  .done-error {
    background: #fef2f2;
    color: #991b1b;
    border: 1px solid #fca5a5;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
  }

  /* Read-only metadata display */
  .done-stats {
    display: flex;
    gap: 1rem;
    margin-top: 0.3rem;
    font-size: 0.8rem;
    color: #888;
  }
  .done-field {
    margin-bottom: 0.875rem;
  }
  .done-field label {
    display: block;
    font-size: 0.8rem;
    font-weight: 500;
    color: #444;
    margin-bottom: 0.3rem;
  }
  .done-field-row {
    display: flex;
    gap: 1rem;
  }
  .done-field-row .done-field {
    flex: 1;
  }
  .done-value {
    font-size: 0.875rem;
    color: #1a1a1a;
    padding: 0.5rem 0.75rem;
    background: #f9f9f9;
    border: 1px solid #e5e5e5;
    border-radius: 6px;
  }
  .done-textarea {
    font-size: 0.875rem;
    color: #1a1a1a;
    padding: 0.5rem 0.75rem;
    background: #f9f9f9;
    border: 1px solid #e5e5e5;
    border-radius: 6px;
    white-space: pre-wrap;
    word-break: break-word;
    min-height: 80px;
    max-height: 240px;
    overflow-y: auto;
    line-height: 1.5;
  }
  .done-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .done-tag {
    font-size: 0.75rem;
    background: #f0f0f0;
    color: #555;
    border-radius: 4px;
    padding: 0.2rem 0.5rem;
  }
  .done-back-btn {
    margin-top: 0.5rem;
  }

  /* Upload card */
  .upload-card {
    position: fixed;
    bottom: 1.25rem;
    left: 1.25rem;
    width: 290px;
    background: white;
    border: 1px solid #e5e5e5;
    border-radius: 10px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    padding: 0.875rem 1rem;
    display: none;
    flex-direction: column;
    gap: 0.5rem;
    z-index: 100;
  }
  .upload-card.visible {
    display: flex;
  }
  .upload-card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .upload-card-title {
    font-size: 0.82rem;
    font-weight: 600;
    color: #1a1a1a;
  }
  .upload-card-filename {
    font-size: 0.78rem;
    color: #555;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .upload-progress-track {
    width: 100%;
    height: 5px;
    background: #f0f0f0;
    border-radius: 999px;
    overflow: hidden;
  }
  .upload-progress-bar {
    height: 100%;
    background: #2563eb;
    border-radius: 999px;
    width: 0%;
    transition: width 0.6s ease;
  }
  .upload-card-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: #888;
  }
  .upload-card-quota {
    font-size: 0.72rem;
    color: #aaa;
    border-top: 1px solid #f0f0f0;
    padding-top: 0.4rem;
    margin-top: 0.1rem;
  }
  .upload-card-quota.warn {
    color: #dc2626;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  .upload-spinner {
    width: 14px;
    height: 14px;
    border: 2px solid #e5e5e5;
    border-top-color: #2563eb;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    flex-shrink: 0;
  }
</style>

<script>
  // File list polling + selection bridge
  //-----------------------------------------------------------------------------------------------

  const fileList = document.getElementById("fileList")!;
  const fileCount = document.getElementById("fileCount")!;
  const donePanel = document.getElementById("donePanel")!;
  const donePanelUploadForm = document.querySelector(
    ".panel-right",
  ) as HTMLElement;

  let selectedFile: string | null = null;
  let selectedVideoId: string | null = null;

  function showUploadForm() {
    if (donePanelUploadForm) donePanelUploadForm.style.display = "flex";
    donePanel.style.display = "none";
  }

  function showDonePanel() {
    if (donePanelUploadForm) donePanelUploadForm.style.display = "none";
    donePanel.style.display = "flex";
  }

  // Done panel logic
  //----------------------------------------------------------------------------------------------- 

  const ytLinkBtn = document.getElementById("ytLinkBtn") as HTMLAnchorElement;
  const doneLoading = document.getElementById("doneLoading")!;
  const doneError = document.getElementById("doneError")!;
  const doneMeta = document.getElementById("doneMeta")!;
  const doneTitle = document.getElementById("doneTitle")!;
  const doneStats = document.getElementById("doneStats")!;
  const doneDescription = document.getElementById("doneDescription")!;
  const doneTags = document.getElementById("doneTags")!;
  const donePrivacy = document.getElementById("donePrivacy")!;
  const donePublished = document.getElementById("donePublished")!;
  const doneBackBtn = document.getElementById("doneBackBtn")!;

  doneBackBtn.addEventListener("click", () => {
    selectedFile = null;
    selectedVideoId = null;
    showUploadForm();
    refreshFileList();
  });

  async function loadDoneMeta(videoId: string) {
    doneLoading.style.display = "flex";
    doneError.style.display = "none";
    doneMeta.style.display = "none";

    try {
      const res = await fetch(
        `/api/youtube-meta?videoId=${encodeURIComponent(videoId)}`,
      );
      const data = (await res.json()) as {
        id?: string;
        title?: string;
        description?: string;
        tags?: string[];
        privacyStatus?: string;
        publishedAt?: string;
        viewCount?: string;
        likeCount?: string;
        youtubeUrl?: string;
        error?: string;
      };

      if (!res.ok || data.error) {
        doneLoading.style.display = "none";
        doneError.style.display = "block";
        doneError.textContent =
          data.error ?? "Failed to load metadata from YouTube.";
        return;
      }

      ytLinkBtn.href = data.youtubeUrl ?? `https://youtu.be/${videoId}`;

      doneTitle.textContent = data.title ?? "";
      doneDescription.textContent = data.description ?? "";

      doneStats.innerHTML = [
        data.viewCount !== undefined
          ? `👁 ${Number(data.viewCount).toLocaleString()} views`
          : "",
        data.likeCount !== undefined
          ? `👍 ${Number(data.likeCount).toLocaleString()} likes`
          : "",
      ]
        .filter(Boolean)
        .join("&nbsp;&nbsp;·&nbsp;&nbsp;");

      doneTags.innerHTML = (data.tags ?? []).length
        ? data.tags!.map((t) => `<span class="done-tag">${t}</span>`).join("")
        : `<span style="color:#aaa;font-size:0.8rem">No tags</span>`;

      const privacyLabel: Record<string, string> = {
        public: "Public",
        private: "Private",
        unlisted: "Unlisted",
      };
      donePrivacy.textContent =
        privacyLabel[data.privacyStatus ?? ""] ?? data.privacyStatus ?? "-";

      donePublished.textContent = data.publishedAt
        ? new Date(data.publishedAt).toLocaleString()
        : "-";

      doneLoading.style.display = "none";
      doneMeta.style.display = "block";
    } catch (err) {
      doneLoading.style.display = "none";
      doneError.style.display = "block";
      doneError.textContent = "Network error loading YouTube metadata.";
    }
  }

  // Listen for done file selection from the polling loop
  window.addEventListener("done-file-selected", (e: Event) => {
    const { videoId } = (e as CustomEvent<{ videoId: string }>).detail;
    selectedVideoId = videoId;
    showDonePanel();
    loadDoneMeta(videoId);
  });

  // File list polling
  //-----------------------------------------------------------------------------------------------

  async function refreshFileList() {
    try {
      const [filesRes, queueRes] = await Promise.all([
        fetch("/api/files"),
        fetch("/api/enqueue"),
      ]);
      const { files } = (await filesRes.json()) as {
        files: {
          name: string;
          path: string;
          addedAt: string;
          hasMeta: boolean;
        }[];
      };
      const { queue, history } = (await queueRes.json()) as {
        queue: {
          fileName: string;
          status: string;
          youtubeVideoId?: string | null;
        }[];
        history: {
          fileName: string;
          status: string;
          youtubeVideoId?: string | null;
        }[];
      };

      // Build a map of fileName -> { status, youtubeVideoId }
      const queueMap = new Map<
        string,
        { status: string; videoId: string | null }
      >();
      for (const e of queue)
        queueMap.set(e.fileName, {
          status: e.status,
          videoId: e.youtubeVideoId ?? null,
        });
      for (const e of history)
        queueMap.set(e.fileName, {
          status: e.status,
          videoId: e.youtubeVideoId ?? null,
        });

      fileCount.textContent = String(files.length);

      if (files.length === 0) {
        fileList.innerHTML = `<div class="file-empty"><p>No video files detected.<br/>Drop a file into <code>/videos</code>.</p></div>`;
        return;
      }

      fileList.innerHTML = files
        .map((f) => {
          const entry = queueMap.get(f.name);
          const status = entry?.status ?? "";
          const statusClass = status ? ` ${status}` : "";
          const badge = status
            ? `<span class="badge badge-${status}">${status}</span>`
            : "";
          const added = new Date(f.addedAt).toLocaleString();
          const isSelected = selectedFile === f.name ? " selected" : "";
          const videoId = entry?.videoId ?? "";

          return `
          <div class="file-item${statusClass}${isSelected}"
            data-name="${f.name}" data-path="${f.path}"
            data-has-meta="${f.hasMeta ? "1" : "0"}"
            data-status="${status}"
            data-video-id="${videoId}">
          <div class="file-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="23 7 16 12 23 17 23 7"/>
              <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
            </svg>
          </div>
          <div class="file-info">
            <div class="file-name-row">
              <span class="file-name">${f.name}</span>
              ${f.hasMeta ? '<span class="meta-badge" title=".meta.json found - form will be pre-filled">META</span>' : ""}
            </div>
            <div class="file-meta">${added}</div>
          </div>
          ${badge}
          </div>`;
        })
        .join("");

      // Attach click handlers
      fileList.querySelectorAll<HTMLElement>(".file-item").forEach((el) => {
        el.addEventListener("click", () => {
          const name = el.getAttribute("data-name")!;
          const status = el.dataset.status ?? "";
          const videoId = el.dataset.videoId ?? "";
          selectedFile = name;

          if (status === "done" && videoId) {
            window.dispatchEvent(
              new CustomEvent("done-file-selected", {
                detail: { name, videoId },
              }),
            );
          } else {
            const hasMeta = el.dataset.hasMeta === "1";
            window.dispatchEvent(
              new CustomEvent("file-selected", { detail: { name, hasMeta } }),
            );
            showUploadForm();
          }
          refreshFileList();
        });
      });
    } catch (err) {
      console.error("[ui] refreshFileList error:", err);
    }
  }

  window.addEventListener("refresh-files", () => refreshFileList());
  refreshFileList();
  setInterval(refreshFileList, 5000);

  // Progress card polling
  //-----------------------------------------------------------------------------------------------

  const uploadCard = document.getElementById("uploadCard")!;
  const uploadCardFilename = document.getElementById("uploadCardFilename")!;
  const uploadProgressBar = document.getElementById("uploadProgressBar")!;
  const uploadCardPercent = document.getElementById("uploadCardPercent")!;
  const uploadCardSpeed = document.getElementById("uploadCardSpeed")!;
  const uploadCardQuota = document.getElementById("uploadCardQuota")!;

  function formatSpeed(bytes: number): string {
    if (bytes < 1024) return `${bytes} B/s`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB/s`;
    return `${(bytes / 1024 / 1024).toFixed(1)} MB/s`;
  }

  async function refreshProgress() {
    try {
      const res = await fetch("/api/progress");
      const data = (await res.json()) as {
        active: boolean;
        fileName?: string;
        percent?: number;
        speedBps?: number | null;
        quota?: { used: number; limit: number; remaining: number };
      };

      // Always update quota display regardless of active state
      if (data.quota) {
        const { used, limit, remaining } = data.quota;
        uploadCardQuota.textContent = `Quota: ${used.toLocaleString()} / ${limit.toLocaleString()} units used today (est.)`;
        uploadCardQuota.classList.toggle("warn", remaining < 1600);
      }

      if (!data.active) {
        uploadCard.classList.remove("visible");
        return;
      }

      uploadCard.classList.add("visible");
      uploadCardFilename.textContent = data.fileName ?? "";
      const pct = data.percent ?? 0;
      uploadProgressBar.style.width = `${pct}%`;
      uploadCardPercent.textContent = `${pct}%`;
      uploadCardSpeed.textContent = data.speedBps
        ? formatSpeed(data.speedBps)
        : "";
    } catch {
      // Silent
    }
  }

  refreshProgress();
  setInterval(refreshProgress, 1500);
</script>
